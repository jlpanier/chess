<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Chess.Views.PromotionPopup"
    Padding="0"
    Margin="0"
    BackgroundColor="#FFFFFF"
    >
    <toolkit:Popup.Shadow>
        <Shadow Brush="Black" Opacity="0.3" Radius="12"/>
    </toolkit:Popup.Shadow>

    <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">

        <HorizontalStackLayout.Resources>
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="ChessMerida"/>
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="TextColor" Value="Black"/>
                <Setter Property="WidthRequest" Value="60"/>
                <Setter Property="HeightRequest" Value="60"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BackgroundColor" Value="#FFFFFFFF"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Command" Value="{Binding SelectCommand}"/>
                <Setter Property="BorderColor" Value="#DDDDDD"/>
                <Setter Property="BorderWidth" Value="1"/>
            </Style>
        </HorizontalStackLayout.Resources>
        
        <!-- Dame -->
        <Button Text="♕" CommandParameter="Queen" />

        <!-- Tour -->
        <Button Text="♖" CommandParameter="Rook"/>

        <!-- Fou -->
        <Button Text="♗" CommandParameter="Bishop"/>

        <!-- Cavalier -->
        <Button Text="♘" CommandParameter="Knight"/>

    </HorizontalStackLayout>

</toolkit:Popup>

    